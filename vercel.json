{
  "version": 2,
  "builds": [
    { "src": "landing/index.html", "use": "@vercel/static" },
    { "src": "landing/style.css", "use": "@vercel/static" },
    { "src": "landing/script.js", "use": "@vercel/static" },
    { "src": "landing/sections/*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "landing/index.html" },
    { "src": "/about", "dest": "landing/sections/about.html" },
    { "src": "/contacto", "dest": "landing/sections/contacto.html" },
    { "src": "/roadmap", "dest": "landing/sections/roadmap.html" },
    { "src": "/whitepaper", "dest": "landing/sections/whitepaper.html" }
  ]
}
